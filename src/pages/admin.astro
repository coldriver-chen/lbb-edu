---
import Layout from '../layouts/Layout.astro';
import { actions } from "astro:actions";
const uploadResult = Astro.getActionResult(actions.uploadPdf);

// 文件路径选项字典（由你负责填充每个选项对应的实际路径）
const pathOptions = {
	'literature-fiber-bionic': 'public/literatures/光纤仿生传感', // 文献阅读 / 光纤仿生传感
	'literature-fiber-biomedical': 'public/literatures/光纤生物医学传感', // 文献阅读 / 光纤生物医学传感
	'literature-other': 'public/literatures/其他交叉领域', // 文献阅读 / 其他交叉领域
	'meeting-formal': 'public/group-meetings/正式组会', // 组会记录 / 正式组会
	'meeting-self-fiber-bionic': 'public/group-meetings/自主组会/光纤仿生传感', // 组会记录 / 自主组会 / 光纤仿生传感
	'meeting-self-other': 'public/group-meetings/自主组会/其他交叉领域', // 组会记录 / 自主组会 / 其他交叉领域
};
---

<Layout title="文献管理面板">
	<div class="admin-container">
		<div class="admin-card">
			<div class="admin-header">
				<h1>文献管理面板</h1>
			</div>

			<form method="POST" enctype="multipart/form-data" action={actions.uploadPdf} class="upload-form">
				<div class="form-group">
					<label for="category">文献类别</label>
					<select
						id="category"
						name="category"
						required
						class="form-input"
					>
						<option value="" disabled selected>请选择文件类别</option>
						<option value={pathOptions['literature-fiber-bionic']}>文献阅读 / 光纤仿生传感</option>
						<option value={pathOptions['literature-fiber-biomedical']}>文献阅读 / 光纤生物医学传感</option>
						<option value={pathOptions['literature-other']}>文献阅读 / 其他交叉领域</option>
						<option value={pathOptions['meeting-formal']}>组会记录 / 正式组会</option>
						<option value={pathOptions['meeting-self-fiber-bionic']}>组会记录 / 自主组会 / 光纤仿生传感</option>
						<option value={pathOptions['meeting-self-other']}>组会记录 / 自主组会 / 其他交叉领域</option>
					</select>
					<span class="form-hint">选择文件保存的目录</span>
				</div>

				<!-- 隐藏字段，用于提交完整的文件路径（文件夹+文件名） -->
				<input type="hidden" id="path" name="path" />

				<div class="form-group">
					<label for="file">选择 PDF 文件</label>
					<div class="file-upload-wrapper">
						<input
							type="file"
							id="file"
							name="file"
							accept="application/pdf"
							required
							class="file-input"
						/>
						<div class="file-upload-label" onclick="document.getElementById('file').click()">
							<span class="upload-icon">📄</span>
							<span class="upload-text">点击选择或拖拽 PDF 文件</span>
						</div>
					</div>
				</div>

				<div class="form-group">
					<label for="admin_token">管理员令牌</label>
					<input
						type="password"
						id="admin_token"
						name="admin_token"
						placeholder="请输入管理员令牌"
						required
						class="form-input"
					/>
					<span class="form-hint">用于身份验证的安全令牌</span>
				</div>

				<button type="submit" class="submit-btn">
					<span class="btn-icon">⬆️</span>
					<span>上传文件</span>
				</button>
			</form>

			{uploadResult && (
				<div class={`result-message ${uploadResult.data?.success ? 'success' : 'error'}`}>
					{uploadResult.data?.success ? (
						<>
							<span class="result-icon">✓</span>
							<p>上传成功！</p>
						</>
					) : (
						<>
							<span class="result-icon">✗</span>
							<p>上传失败！</p>
							{uploadResult.data?.message}
						</>
					)}
				</div>
			)}
		</div>
	</div>
</Layout>

<style>
	.admin-container {
		min-height: calc(100vh - 70px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 40px 20px;
		background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
	}

	.admin-card {
		background: #ffffff;
		border-radius: 16px;
		box-shadow: 0 10px 40px rgba(0, 59, 130, 0.1);
		padding: 40px;
		width: 100%;
		max-width: 600px;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.admin-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 15px 50px rgba(0, 59, 130, 0.15);
	}

	.admin-header {
		text-align: center;
		margin-bottom: 35px;
	}

	.admin-header h1 {
		font-size: 28px;
		color: #003b82;
		margin: 0 0 10px 0;
		font-weight: 600;
	}

	.admin-subtitle {
		color: #666;
		font-size: 14px;
		margin: 0;
	}

	.upload-form {
		display: flex;
		flex-direction: column;
		gap: 24px;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.form-group label {
		font-size: 14px;
		font-weight: 500;
		color: #333;
		margin-bottom: 4px;
	}

	.form-input {
		padding: 12px 16px;
		border: 2px solid #e0e0e0;
		border-radius: 8px;
		font-size: 14px;
		transition: all 0.3s ease;
		background: #fafafa;
		width: 100%;
	}

	.form-input:focus {
		outline: none;
		border-color: #003b82;
		background: #ffffff;
		box-shadow: 0 0 0 3px rgba(0, 59, 130, 0.1);
	}

	.form-input::placeholder {
		color: #aaa;
	}

	.form-hint {
		font-size: 12px;
		color: #999;
		margin-top: 4px;
	}

	.file-upload-wrapper {
		position: relative;
	}

	.file-input {
		position: absolute;
		width: 0.1px;
		height: 0.1px;
		opacity: 0;
		overflow: hidden;
		z-index: -1;
	}

	.file-upload-label {
		padding: 20px;
		border: 2px dashed #d0d0d0;
		border-radius: 8px;
		text-align: center;
		cursor: pointer;
		transition: all 0.3s ease;
		background: #fafafa;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
	}

	.file-upload-label:hover {
		border-color: #003b82;
		background: #f0f5ff;
	}

	.file-input:focus + .file-upload-label {
		border-color: #003b82;
		background: #f0f5ff;
		box-shadow: 0 0 0 3px rgba(0, 59, 130, 0.1);
	}

	.upload-icon {
		font-size: 32px;
	}

	.upload-text {
		font-size: 14px;
		color: #666;
	}

	.submit-btn {
		padding: 14px 24px;
		background: linear-gradient(135deg, #003b82 0%, #0056b3 100%);
		color: white;
		border: none;
		border-radius: 8px;
		font-size: 16px;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.3s ease;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		margin-top: 10px;
	}

	.submit-btn:hover {
		background: linear-gradient(135deg, #002d66 0%, #004a99 100%);
		transform: translateY(-2px);
		box-shadow: 0 5px 15px rgba(0, 59, 130, 0.3);
	}

	.submit-btn:active {
		transform: translateY(0);
	}

	.btn-icon {
		font-size: 18px;
	}

	.result-message {
		margin-top: 24px;
		padding: 16px;
		border-radius: 8px;
		display: flex;
		align-items: center;
		gap: 12px;
		animation: slideIn 0.3s ease;
	}

	@keyframes slideIn {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.result-message.success {
		background: #e8f5e9;
		border: 1px solid #4caf50;
		color: #2e7d32;
	}

	.result-message.error {
		background: #ffebee;
		border: 1px solid #f44336;
		color: #c62828;
	}

	.result-icon {
		font-size: 24px;
		font-weight: bold;
	}

	.result-message p {
		margin: 0;
		font-size: 14px;
	}

	.error-detail {
		font-size: 12px;
		margin-top: 4px;
		opacity: 0.8;
	}

	@media (max-width: 768px) {
		.admin-card {
			padding: 30px 20px;
		}

		admin-header h1 {
			font-size: 24px;
		}
	}
</style>

<script>
// 管理员令牌自动保存和填充功能
// 文件选择显示文件名并拼接完整路径功能
document.addEventListener('DOMContentLoaded', () => {
	const tokenInput = document.getElementById('admin_token') as HTMLInputElement;
	const form = document.querySelector('.upload-form');
	const fileInput = document.getElementById('file') as HTMLInputElement;
	const uploadText = document.querySelector('.upload-text');
	const categorySelect = document.getElementById('category') as HTMLSelectElement;
	const hiddenPathInput = document.getElementById('path') as HTMLInputElement;
	
	if (!tokenInput || !form) return;
	
	// 页面加载时从 localStorage 读取保存的令牌
	const savedToken = localStorage.getItem('admin_token');
	if (savedToken) {
		tokenInput.value = savedToken;
	}
	
	// 表单提交时保存令牌到 localStorage
	form.addEventListener('submit', () => {
		const currentToken = tokenInput.value;
		if (currentToken) {
			localStorage.setItem('admin_token', currentToken);
		}
	});
	
	// 添加提示：如果已有保存的令牌，显示提示
	if (savedToken && tokenInput.parentElement) {
		const hintElement = tokenInput.parentElement.querySelector('.form-hint') as HTMLElement;
		if (hintElement) {
			hintElement.textContent = '已自动填充上次使用的令牌';
			hintElement.style.color = '#4caf50';
		}
	}
	
	// 更新完整路径（文件夹 + 文件名）
	const updateFullPath = () => {
		if (!categorySelect || !hiddenPathInput || !fileInput) return;
		
		const selectedPath = categorySelect.value; // 选中的文件夹路径
		const fileName = fileInput.files?.[0]?.name; // 上传的文件名
		
		if (selectedPath && fileName) {
			// 拼接完整路径：文件夹/文件名
			const fullPath = `${selectedPath}/${fileName}`;
			hiddenPathInput.value = fullPath;
		} else {
			hiddenPathInput.value = '';
		}
	};
	
	// 文件选择后显示文件名并更新完整路径
	if (fileInput && uploadText) {
		fileInput.addEventListener('change', (e) => {
			const target = e.target as HTMLInputElement;
			if (target.files && target.files.length > 0) {
				const fileName = target.files[0].name;
				(uploadText as HTMLElement).textContent = `已选择: ${fileName}`;
				(uploadText as HTMLElement).style.color = '#003b82';
			} else {
				(uploadText as HTMLElement).textContent = '点击选择或拖拽 PDF 文件';
				(uploadText as HTMLElement).style.color = '#666';
			}
			updateFullPath();
		});
	}
	
	// 类别改变时也更新完整路径
	if (categorySelect) {
		categorySelect.addEventListener('change', () => {
			updateFullPath();
		});
	}
});
</script>