---
import Layout from '../layouts/Layout.astro';
import { actions } from "astro:actions";
const uploadResult = Astro.getActionResult(actions.uploadPdf);
---

<Layout>

<form method="POST" enctype="multipart/form-data" 
  action={actions.uploadPdf}>
  <input
    type="text"
    name="path"
    placeholder="例如：pdfs/demo.pdf"
    required
  />

  <input
    type="file"
    name="file"
    accept="application/pdf"
    required
  />

  <button type="submit">上传</button>
</form>

{
  uploadResult?.data?.success && (
    <p>提交成功！</p>
  )
}
</Layout>