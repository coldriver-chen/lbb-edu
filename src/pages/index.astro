---
import Layout from '../layouts/Layout.astro';
import teacherInfo from '../data/teacher-info.json';
import relatedTeachers from '../data/related-teachers.json';

// 直接导入 MDX 文件
import Profile from '../content/profile.mdx';
import Research from '../content/research.mdx';
import AcademicNews from '../content/academic-news.mdx';
import GroupNews from '../content/group-news.mdx';
import LiteratureList from '../components/LiteratureList.astro';

const tabContents = [
  { id: 'profile', title: '个人简介', Component: Profile },
  { id: 'research', title: '研究方向', Component: Research },
  { id: 'academic-news', title: '学术资讯', Component: AcademicNews },
  { id: 'group-news', title: '课题组新闻', Component: GroupNews },
  { id: 'literature', title: '文献阅读', Component: LiteratureList },
];

---

<Layout>
	<!-- 顶部 -->
	<header class="header">
	    <div class="header-inner">

	        <div class="logo">
	            <img src="/logo.png" alt="重庆理工大学" class="logo-img" />
	            <div class="logo-text">
	                <p>教师个人主页</p>
	            </div>
	        </div>

	        <nav class="nav">
	            <a href="#">首页</a>
	            <a href="#">学院概况</a>
	            <a href="#">师资队伍</a>
	            <a href="#">关于主页</a>
	        </nav>

	    </div>
	</header>

	<!-- 主体 -->
	
	<!-- 教师介绍区块（独占一行） -->
	<div class="container">
	    <div class="teacher-intro">
	        <div class="teacher-intro-left">
	            <div class="teacher-photo">
	                <img src="/lbb.png" alt="罗彬彬老师" />
	            </div>
	            <div class="teacher-info">
	                <div class="teacher-header">
	                    <div class="teacher-name-row">
	                        <h3>{teacherInfo.name}</h3>
	                        <span class="teacher-title">{teacherInfo.title}</span>
	                    </div>
	                    <div class="teacher-unit">
	                        <span>单位 {teacherInfo.unit}</span>
	                    </div>
	                </div>
	                <div class="teacher-position">{teacherInfo.position}</div>
	                <div class="teacher-contact">
	                    <div class="contact-item">
	                        <span class="contact-icon">📞</span>
	                        <span>电话 {teacherInfo.phone}</span>
	                    </div>
	                    <div class="contact-item">
	                        <span class="contact-icon">📱</span>
	                        <span>微信电话 {teacherInfo.wechat_phone}</span>
	                    </div>
	                    <div class="contact-item">
	                        <span class="contact-icon">✉️</span>
	                        <span>邮箱 {teacherInfo.email}</span>
	                    </div>
	                    <div class="contact-item">
	                        <span class="contact-icon">📍</span>
	                        <span>地址 {teacherInfo.address}</span>
	                    </div>
	                </div>
	                <div class="teacher-research">
	                    <span class="contact-icon">🔬</span>
	                    <span>研究方向 {teacherInfo.researchDirections.join(';\n')}</span>
	                </div>
	            </div>
	        </div>
	        <div class="teacher-intro-right">
	            <div class="qr-code">
	                <!-- 二维码占位 -->
	            </div>
	            <div class="update-info">
	                <p>更新时间：{teacherInfo.updateTime}</p>
	                <p>总访问量：{teacherInfo.totalVisits}</p>
	            </div>
	        </div>
	    </div>
	</div>
	
	<div class="container">
	    <!-- 左侧菜单 -->
	    <aside class="sidebar">


	        <div class="menu" id="menu-container">
	            {tabContents.map((item, index) => (
	                <div 
	                    class={`menu-item ${index === 0 ? 'active' : ''}`}
	                    data-content={item.id}
	                >
	                    <span>{item.title}</span>
	                    <span>></span>
	                </div>
	            ))}
	        </div>
	        <div class="link-box">
	            <h4>链接</h4>
	            <a href="https://www.cqut.edu.cn/">重庆理工大学</a>
	        </div>

	    </aside>

	    <!-- 右侧内容 -->
	    <main class="content">
	        {tabContents.map((item, index) => {
	            const Component = item.Component;
	            return (
	                <div 
	                    class={`content-section ${index === 0 ? 'active' : ''}`}
	                    id={`content-${item.id}`}
	                >
	                    <Component />
	                </div>
	            );
	        })}

	    </main>

	</div>

	<!-- 相关教师区块（独占一行） -->
	<div class="container">
	    <div class="related-section">
	        <div class="related-header">
	            <div class="related-title">
	                相关教师
	            </div>
	        </div>

	        <div class="teacher-list">
	            {relatedTeachers.teachers.map((teacher) => (
	                <div class="teacher-card">
	                    <div class="teacher-avatar">
	                        <img src={teacher.photo} alt={teacher.name} />
	                    </div>
	                    <div class="teacher-name">{teacher.name}</div>
	                    <div class="teacher-dept">{teacher.title}</div>
	                </div>
	            ))}
	        </div>

	    </div>
	</div>

	<!-- 页脚 -->
	<footer class="footer">
	    Copyright © 2007-2030 {teacherInfo.name} 教师个人主页<br/>
	    电话：{teacherInfo.phone} | Email：{teacherInfo.email}
	</footer>
</Layout>

<style>
/* ===== 顶部导航 ===== */
.header{
    background:#003b82;
    height:70px;
    border-bottom:1px solid #2d5d9b;
}

.header-inner{
    width:1200px;
    margin:auto;
    height:70px;
    display:flex;
    align-items:center;
    justify-content:space-between;
}

.logo{
    display:flex;
    align-items:center;
}

.logo-img{
    height:50px;
    margin-right:15px;
    object-fit: contain;
}

.logo-text{
    line-height:1.4;
    text-align:right;
    display:flex;
    align-items:center;
    height:50px;
}

.logo-text p{
    font-size:20px;
}

.nav{
    display:flex;
    gap:40px;
}

.nav a{
    font-size:15px;
    color:#fff;
}

/* ===== 主体 ===== */

.container{
    width:1200px;
    margin:30px auto;
    display:flex;
    gap:30px;
}

/* 左侧菜单 */

.sidebar{
    width:220px;
}

.menu{
    background:#fff;
    border:1px solid #e0e0e0;
}

.menu-item{
    height:48px;
    line-height:48px;
    padding:0 18px;
    border-bottom:1px solid #e0e0e0;
    display:flex;
    justify-content:space-between;
    cursor:pointer;
    color:#333;
}

.menu-item:hover{
    background:#f0f0f0;
}

.link-box{
    margin-top:20px;
    background:#fff;
    border:1px solid #e0e0e0;
    padding:15px;
}

.link-box h4{
    color:#003b82;
    margin-bottom:10px;
}

.link-box a{
    display:block;
    margin-bottom:8px;
    font-size:14px;
    color:#333;
}

/* 内容区域 */

.content{
    flex:1;
    background:#fff;
    padding:25px;
}

/* 教师介绍区块 */

.teacher-intro{
    background:#fff;
    padding:20px;
    display:flex;
    justify-content:space-between;
    width: 100%;
    box-sizing: border-box;
    border:1px solid #e0e0e0;
}

.teacher-intro-left{
    display:flex;
    gap:20px;
    flex:1;
}

.teacher-photo{
    width:120px;
    height:150px;
    background:#e0e0e0;
    flex-shrink:0;
    overflow:hidden;
}

.teacher-photo img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.teacher-info{
    flex:1;
}

.teacher-header{
    display:flex;
    align-items:center;
    gap:20px;
    margin-bottom:8px;
}

.teacher-name-row{
    display:flex;
    align-items:center;
    gap:10px;
}

.teacher-name-row h3{
    font-size:28px;
    color:#003b82;
    margin:0;
}

.teacher-title{
    background:#e8e8e8;
    padding:2px 8px;
    border-radius:4px;
    font-size:12px;
    color:#666;
}

.teacher-unit{
    font-size:14px;
    color:#666;
    padding-left:20px;
    border-left:1px solid #e0e0e0;
}

.teacher-position{
    font-size:14px;
    color:#333;
    margin-bottom:12px;
}

.teacher-contact{
    display:flex;
    gap:20px;
    margin-bottom:8px;
    font-size:13px;
    color:#666;
}

.contact-item{
    display:flex;
    align-items:center;
    gap:5px;
}

.teacher-research{
    font-size:13px;
    color:#666;
    display:flex;
    align-items:center;
    gap:5px;
}

.teacher-intro-right{
    display:flex;
    flex-direction:column;
    align-items:flex-end;
    gap:10px;
}

.qr-code{
    width:80px;
    height:80px;
    background:#e0e0e0;
}

.update-info{
    text-align:right;
    font-size:12px;
    color:#999;
    line-height:1.8;
}

.profile-text{
    line-height:1.9;
    font-size:14px;
    color:#333;
}

.team-photo{
    margin-top:25px;
    width:100%;
    height:420px;
    background:#e0e0e0;
    display:flex;
    align-items:center;
    justify-content:center;
    color:#666;
    font-size:22px;
}

/* 相关教师区块 */

.related-section{
    background:#fff;
    border:1px solid #e0e0e0;
    padding:20px;
    width: 100%;
    box-sizing: border-box;
}

.related-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

.related-title{
    color:#003b82;
    font-size:16px;
    font-weight:bold;
}

.refresh-btn{
    display:flex;
    align-items:center;
    gap:5px;
    font-size:13px;
    color:#666;
    cursor:pointer;
}

.refresh-btn:hover{
    color:#003b82;
}

.teacher-list{
    display:flex;
    gap:20px;
    flex-wrap:wrap;
    justify-content:flex-start;
}

.teacher-card{
    width:90px;
    text-align:center;
}

.teacher-avatar{
    width:90px;
    height:110px;
    background:#e0e0e0;
    margin:0 auto;
    overflow:hidden;
}

.teacher-avatar img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.teacher-name{
    margin-top:8px;
    font-size:13px;
    color:#333;
    font-weight:500;
}

.teacher-dept{
    margin-top:4px;
    font-size:12px;
    color:#666;
    overflow:hidden;
    text-overflow:ellipsis;
    white-space:nowrap;
}

/* 页脚 */

.footer{
    margin-top:40px;
    background:#fff;
    border-top:1px solid #e0e0e0;
    text-align:center;
    padding:25px;
    color:#666;
    font-size:13px;
}

/* 菜单激活状态 */
.menu-item.active{
    background:#003b82;
    color:#fff;
}

.menu-item.active span{
    color:#fff;
}

/* 内容区域切换 */
.content-section{
    display:none;
}

.content-section.active{
    display:block;
}

/* MDX 内容样式 */
.content-section h1{
    font-size:24px;
    color:#003b82;
    margin-bottom:20px;
    border-bottom:2px solid #003b82;
    padding-bottom:10px;
}

.content-section h2{
    font-size:20px;
    color:#003b82;
    margin-top:25px;
    margin-bottom:15px;
}

.content-section h3{
    font-size:18px;
    color:#333;
    margin-top:20px;
    margin-bottom:10px;
}

.content-section p{
    line-height:1.8;
    margin-bottom:12px;
    color:#333;
}

.content-section ul,
.content-section ol{
    padding-left:25px;
    margin-bottom:15px;
}

.content-section li{
    line-height:1.8;
    margin-bottom:8px;
    color:#333;
}

.content-section strong{
    color:#003b82;
}

.content-section table{
    width:100%;
    border-collapse:collapse;
    margin:20px 0;
}

.content-section th,
.content-section td{
    border:1px solid #e0e0e0;
    padding:10px;
    text-align:left;
}

.content-section th{
    background:#f5f5f5;
    font-weight:bold;
    color:#003b82;
}
</style>

<script>
// 内容切换功能
document.addEventListener('DOMContentLoaded', () => {
    const menuContainer = document.getElementById('menu-container');
    if (!menuContainer) return;
    
    menuContainer.addEventListener('click', (e) => {
        const menuItem = (e.target as HTMLElement).closest('.menu-item');
        if (!menuItem) return;
        
        // 移除所有菜单项的 active 类
        document.querySelectorAll('.menu-item').forEach(item => {
            item.classList.remove('active');
        });
        
        // 给当前点击的菜单项添加 active 类
        menuItem.classList.add('active');
        
        // 获取要显示的内容 ID
        const contentId = menuItem.getAttribute('data-content');
        
        // 隐藏所有内容区域
        document.querySelectorAll('.content-section').forEach(section => {
            section.classList.remove('active');
        });
        
        // 显示对应的内容区域
        const targetSection = document.getElementById(`content-${contentId}`);
        if (targetSection) {
            targetSection.classList.add('active');
        }
    });
});
</script>
