---
import path from 'node:path';
import DocumentFolderList from './DocumentFolderList.astro';

const publicDir = path.join(process.cwd(), 'public');
const folders = [
  {
    title: '正式组会',
    dir: path.join(publicDir, 'group-meetings', '正式组会'),
    url: '/group-meetings/正式组会',
  },
  {
    title: '自主组会',
    dir: path.join(publicDir, 'group-meetings', '自主组会'),
    url: '/group-meetings/自主组会',
    children: [
      {
        title: '仿生',
        dir: path.join(publicDir, 'group-meetings', '自主组会', '仿生'),
        url: '/group-meetings/自主组会/仿生',
      },
      {
        title: '交叉',
        dir: path.join(publicDir, 'group-meetings', '自主组会', '交叉'),
        url: '/group-meetings/自主组会/交叉',
      },
    ],
  },
];
---

<DocumentFolderList folders={folders} />
