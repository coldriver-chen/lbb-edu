---
// 读取 public/literatures 目录下的所有 PDF 文件
const pdfFiles = import.meta.glob('/public/literatures/*.pdf', { eager: false });
const fileList = Object.keys(pdfFiles).map(path => {
  const fileName = path.split('/').pop() || '';
  return fileName;
});
---

<div class="literature-list">
  {fileList.length > 0 ? (
    <ul class="pdf-list">
      {fileList.map((file: string) => {
        const fileName = file.replace(/\.pdf$/i, '');
        return (
          <li class="pdf-item">
            <a href={`/literatures/${file}`} download class="pdf-link">
              📄 {fileName}
            </a>
          </li>
        );
      })}
    </ul>
  ) : (
    <p class="empty-message">暂无文献</p>
  )}
</div>

<style>
.literature-list {
  padding: 20px;
}

.pdf-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.pdf-item {
  margin-bottom: 2px;
}

.pdf-link {
  font-size: 13px;
  color: #003b82;
  text-decoration: underline;
  cursor: pointer;
}

.pdf-link:hover {
  color: #0056b3;
}

.empty-message {
  text-align: center;
  padding: 40px;
  color: #999;
  font-size: 14px;
}
</style>
