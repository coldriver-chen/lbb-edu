---
import path from 'node:path';
import DocumentFolderList from './DocumentFolderList.astro';

const publicDir = path.join(process.cwd(), 'public');
const folders = [
  {
    title: '仿生',
    dir: path.join(publicDir, 'literatures', '仿生'),
    url: '/literatures/仿生',
  },
  {
    title: '生物',
    dir: path.join(publicDir, 'literatures', '生物'),
    url: '/literatures/生物',
  },
  {
    title: '交叉',
    dir: path.join(publicDir, 'literatures', '交叉'),
    url: '/literatures/交叉',
  },
];
---

<DocumentFolderList folders={folders} />
