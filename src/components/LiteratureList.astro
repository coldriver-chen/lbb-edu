---
import path from 'node:path';
import DocumentFolderList from './DocumentFolderList.astro';

const publicDir = path.join(process.cwd(), 'public');
const folders = [
  {
    title: '光纤仿生传感',
    dir: path.join(publicDir, 'literatures', '光纤仿生传感'),
    url: '/literatures/光纤仿生传感',
  },
  {
    title: '光纤生物医学传感',
    dir: path.join(publicDir, 'literatures', '光纤生物医学传感'),
    url: '/literatures/光纤生物医学传感',
  },
  {
    title: '其他交叉领域',
    dir: path.join(publicDir, 'literatures', '其他交叉领域'),
    url: '/literatures/其他交叉领域',
  },
];
---

<DocumentFolderList folders={folders} />
