---
import fs from 'node:fs';
import path from 'node:path';

type FolderConfig = {
  title: string;
  dir: string;
  url: string;
  children?: FolderConfig[];
};

type DocumentItem = {
  name: string;
  url: string;
  addedAt: string;
  addedAtIso: string;
};

type FolderView = FolderConfig & {
  id: string;
  documents: DocumentItem[];
  children?: FolderView[];
};

const { folders } = Astro.props as { folders: FolderConfig[] };

const formatDateTime = (date: Date) => {
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(date);
};

const getDocuments = (folder: FolderConfig): DocumentItem[] => {
  if (!fs.existsSync(folder.dir)) return [];

  return fs.readdirSync(folder.dir, { withFileTypes: true })
    .filter((entry) => entry.isFile() && !entry.name.startsWith('.'))
    .map((entry) => {
      const filePath = path.join(folder.dir, entry.name);
      const stat = fs.statSync(filePath);

      return {
        name: entry.name.replace(/\.[^.]+$/, ''),
        url: encodeURI(`${folder.url}/${entry.name}`),
        addedAt: formatDateTime(stat.birthtime),
        addedAtIso: stat.birthtime.toISOString(),
      };
    })
    .sort((a, b) => new Date(b.addedAtIso).getTime() - new Date(a.addedAtIso).getTime());
};

const toFolderView = (folder: FolderConfig, prefix: string): FolderView => ({
  ...folder,
  id: prefix,
  documents: getDocuments(folder),
  children: folder.children?.map((child, index) => toFolderView(child, `${prefix}-${index}`)),
});

const folderViews = folders.map((folder, index) => toFolderView(folder, `folder-${index}`));
---

<div class="document-browser">
  <aside class="document-controls">
    <label>
      <span>分类</span>
      <select class="folder-select" aria-label="选择分类">
        {folderViews.map((folder) => (
          <option value={folder.id}>{folder.title}</option>
        ))}
      </select>
    </label>

    {folderViews.some((folder) => folder.children?.length) && (
      <div class="child-select-wrap">
        {folderViews.map((folder) => folder.children?.length ? (
          <label class="child-select-group" data-parent={folder.id}>
            <span>二级分类</span>
            <select class="child-select" aria-label="选择二级分类" data-parent={folder.id}>
              {folder.children.map((child) => (
                <option value={child.id}>{child.title}</option>
              ))}
            </select>
          </label>
        ) : null)}
      </div>
    )}
  </aside>

  <div class="document-table-area">
    {folderViews.map((folder) => (
      <section class="document-panel" data-panel={folder.id}>
        <h2>{folder.title}</h2>

        {folder.children?.length ? (
          folder.children.map((child) => (
            <div class="document-child-panel" data-child-panel={child.id} data-parent={folder.id}>
              <h3>{child.title}</h3>
              {child.documents.length > 0 ? (
                <table class="document-table">
                  <thead>
                    <tr>
                      <th>文档名称</th>
                    </tr>
                  </thead>
                  <tbody>
                    {child.documents.map((doc) => (
                      <tr>
                        <td><a href={doc.url} download>{doc.name}</a></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              ) : (
                <p class="empty-message">暂无文档</p>
              )}
            </div>
          ))
        ) : folder.documents.length > 0 ? (
          <table class="document-table">
            <thead>
              <tr>
                <th>文档名称</th>
              </tr>
            </thead>
            <tbody>
              {folder.documents.map((doc) => (
                <tr>
                  <td><a href={doc.url} download>{doc.name}</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p class="empty-message">暂无文档</p>
        )}
      </section>
    ))}
  </div>
</div>

<script>
  const browsers = document.querySelectorAll('.document-browser');

  browsers.forEach((browser) => {
    const folderSelect = browser.querySelector<HTMLSelectElement>('.folder-select');
    const panels = browser.querySelectorAll<HTMLElement>('.document-panel');
    const childGroups = browser.querySelectorAll<HTMLElement>('.child-select-group');
    const childSelects = browser.querySelectorAll<HTMLSelectElement>('.child-select');
    const childPanels = browser.querySelectorAll<HTMLElement>('.document-child-panel');

    const update = () => {
      const activeFolder = folderSelect?.value || '';

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.panel !== activeFolder;
      });

      childGroups.forEach((group) => {
        group.hidden = group.dataset.parent !== activeFolder;
      });

      childPanels.forEach((panel) => {
        const activeChildSelect = Array.from(childSelects).find((select) => select.dataset.parent === activeFolder);
        panel.hidden = panel.dataset.parent !== activeFolder || panel.dataset.childPanel !== activeChildSelect?.value;
      });
    };

    folderSelect?.addEventListener('change', update);
    childSelects.forEach((select) => select.addEventListener('change', update));
    update();
  });
</script>

<style>
.document-browser {
  display: grid;
  grid-template-columns: 180px minmax(0, 1fr);
  gap: 22px;
  align-items: start;
}

.document-controls {
  border: 1px solid #e0e0e0;
  background: #fafafa;
  padding: 14px;
}

.document-controls label {
  display: block;
  margin-bottom: 14px;
}

.document-controls label:last-child {
  margin-bottom: 0;
}

.document-controls span {
  display: block;
  margin-bottom: 7px;
  font-size: 13px;
  color: #003b82;
  font-weight: bold;
}

.document-controls select {
  width: 100%;
  height: 34px;
  border: 1px solid #cdd7e3;
  background: #fff;
  color: #333;
  padding: 0 8px;
  font-size: 14px;
}

.document-table-area {
  min-width: 0;
}

.document-panel h2 {
  font-size: 18px;
  color: #003b82;
  margin: 0 0 12px;
  border-bottom: 1px solid #d8e2ef;
  padding-bottom: 8px;
}

.document-panel h3 {
  font-size: 16px;
  color: #333;
  margin: 0 0 12px;
}

.document-table {
  width: 100%;
  border-collapse: collapse;
  margin: 0;
}

.document-table th,
.document-table td {
  border: 1px solid #e0e0e0;
  padding: 10px;
  font-size: 13px;
  vertical-align: middle;
}

.document-table th {
  background: #f5f7fa;
  color: #003b82;
  font-weight: bold;
}

.document-table th:first-child,
.document-table td:first-child {
  width: 70%;
}

.document-table a {
  color: #003b82;
  text-decoration: underline;
  overflow-wrap: anywhere;
}

.document-table time {
  color: #666;
  white-space: nowrap;
}

.empty-message {
  padding: 18px 0;
  color: #999;
  font-size: 13px;
}

@media (max-width: 720px) {
  .document-browser {
    grid-template-columns: 1fr;
  }
}
</style>
